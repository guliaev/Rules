# Точечная блокировка рекламы и аналитики Apple для Shadowrocket.
# Проверено: 2026-07-18.
# Подключать с REJECT непосредственно ПЕРЕД Apple.list,DIRECT.
# Все 29 Apple-доменов из проверенных блок-листов учтены ниже.

# --- Реклама, iAd и атрибуция: активно ---
DOMAIN-SUFFIX,api-adservices.apple.com
DOMAIN-SUFFIX,advertising.apple.com
DOMAIN-SUFFIX,iad.apple.com
DOMAIN-SUFFIX,iadmoo.apple.com
DOMAIN-SUFFIX,iadsdk.apple.com

# DOMAIN-SUFFIX,iadsdk.apple.com уже покрывает все узкие дубли из сторонних списков:
# DOMAIN,ca.iadsdk.apple.com
# DOMAIN,cf.iadsdk.apple.com
# DOMAIN,cs.iadsdk.apple.com
# DOMAIN,news.iadsdk.apple.com
# DOMAIN,su.iadsdk.apple.com
# DOMAIN,tr.iadsdk.apple.com
# DOMAIN,ut.iadsdk.apple.com

# --- Сторонняя аналитика: активно ---
DOMAIN,apple.comscoreresearch.com

# --- Событийная аналитика приложений Apple: активно, средняя уверенность ---
DOMAIN-SUFFIX,weather-analytics-events.apple.com
DOMAIN-SUFFIX,notes-analytics-events.apple.com
DOMAIN-SUFFIX,books-analytics-events.apple.com
DOMAIN-SUFFIX,stocks-analytics-events.apple.com

# --- Возможная телеметрия: сохранена, но отключена ---
# Эти хосты недостаточно отделены от диагностики и служебных функций.
# DOMAIN-SUFFIX,cstat.apple.com
# DOMAIN-SUFFIX,idiagnostics.apple.com
# DOMAIN-SUFFIX,metrics-config.icloud.com
# DOMAIN-SUFFIX,metrics.apple.com
# DOMAIN-SUFFIX,securemetrics.apple.com

# --- Критичные или неоднозначные хосты: отключены ---
# Не раскомментировывать без отдельного теста App Store, iCloud, «Игр» и Game Center.
# DOMAIN-SUFFIX,metrics.icloud.com
# DOMAIN-SUFFIX,metrics.mzstatic.com
# DOMAIN-SUFFIX,stats.gc.apple.com
# DOMAIN-SUFFIX,c.apple.com
# DOMAIN-SUFFIX,qwapi.apple.com

# --- Функциональные iTunes-хосты из старых блок-листов: отключены ---
# Их блокировка может ломать баннеры, виджеты и старые iTunes-ссылки.
# DOMAIN-SUFFIX,autolinkmaker.itunes.apple.com
# DOMAIN-SUFFIX,banners.itunes.apple.com
# DOMAIN-SUFFIX,widgets.itunes.apple.com
